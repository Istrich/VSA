# VSA runtime configuration. All keys are optional; defaults live in
# core/config.py::Settings. Copy this file to `.env` to activate.

# --- Storage locations -----------------------------------------------------
VSA_DATA_DIR=./data
VSA_MODELS_DIR=./models
VSA_INSIGHTFACE_HOME=./models/insightface_home
VSA_SQLITE_FILENAME=metadata.db
VSA_CHROMA_SUBDIR=chroma
VSA_CHROMA_CLIP_COLLECTION=embeddings_clip
VSA_CHROMA_FACES_COLLECTION=embeddings_faces

# --- Ollama ----------------------------------------------------------------
VSA_OLLAMA_BASE_URL=http://localhost:11434
VSA_OLLAMA_NUM_PARALLEL=1
VSA_OLLAMA_TIMEOUT_SEC=120
VSA_OLLAMA_MAX_RETRIES=3
VSA_OLLAMA_CAPTION_MODEL=moondream2
VSA_OLLAMA_SUMMARY_MODEL=llama3

# --- CLIP / Faces ----------------------------------------------------------
VSA_CLIP_MODEL_NAME=ViT-L-14
VSA_CLIP_PRETRAINED=hf-hub:openai/clip-vit-large-patch14
VSA_FACE_MODEL_NAME=buffalo_l

# --- Runtime behavior ------------------------------------------------------
VSA_ALLOW_CPU=true
# Leave VSA_CUDA_RUNTIME_PIN unset to accept any CUDA version. Set it to
# e.g. "12.1" to fail fast on unexpected runtimes in production.
# VSA_CUDA_RUNTIME_PIN=12.1

VSA_LOG_LEVEL=INFO
VSA_MAX_UPLOAD_SIZE_MB=10
